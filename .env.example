# Required in Vercel Project Settings -> Environment Variables
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/
MONGO_DB=boutique_db
JWT_SECRET=replace-with-a-long-random-string
BRIDGE_SECRET=replace-with-another-long-random-string
CRON_SECRET=replace-with-a-random-scheduler-secret
USERNAME=Admin
PASSWORD=replace-with-a-strong-password
PASSWORD_HASH=
ADMIN_EMAIL=

# Optional platform-owner boutique. It reuses PASSWORD/PASSWORD_HASH.
BOUTIQUE_USERNAME=
BOUTIQUE_NAME=

# Google OAuth (server-side authorization code flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID OAuth (use common for personal + work accounts)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Optional canonical public URL, for example https://boutique-manager-react.vercel.app
# Leave blank locally; the API will use the current request origin.
OAUTH_REDIRECT_BASE=

# Encrypts SMTP passwords before MongoDB storage (use a stable random secret)
SMTP_ENCRYPTION_KEY=replace-with-a-long-stable-random-string

# Optional AI provider
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Local development only
PORT=8787
PYTHON_BIN=.venv/bin/python
